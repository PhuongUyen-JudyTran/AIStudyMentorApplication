<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/study_blue_extra_light">

    <!-- Decorative Background Shapes -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_circle_decor"
        android:layout_marginTop="-150dp"
        android:layout_marginEnd="-150dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_circle_decor"
        android:layout_marginBottom="-100dp"
        android:layout_marginStart="-100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Header -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@color/study_blue_dark">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="80dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/desc_back"
                android:src="@drawable/ic_back"
                android:paddingTop="50dp"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/title_quiz"
                android:textColor="@color/white"
                android:textSize="25sp"
                android:paddingTop="50dp"
                android:textStyle="bold" />

        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Quiz Setup Layout -->
    <LinearLayout
        android:id="@+id/layoutQuizSetup"
        android:layout_width="match_parent"
        android:visibility="visible"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_book"
                android:alpha="0.8" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_pencil"
                android:layout_gravity="bottom|end"
                android:layout_marginBottom="-10dp"
                android:layout_marginEnd="-10dp"
                android:rotation="15" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set Up Your Quiz"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/study_blue_dark"
            android:layout_marginBottom="32dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilLevel"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_choose_level"
            android:layout_marginBottom="16dp">

            <AutoCompleteTextView
                android:id="@+id/atvLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:padding="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSubject"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_select_subject"
            android:layout_marginBottom="32dp">

            <AutoCompleteTextView
                android:id="@+id/atvSubject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:padding="16dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateQuiz"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/btn_create_quiz"
            app:backgroundTint="@color/study_blue_dark"
            app:cornerRadius="16dp" />
    </LinearLayout>

    <!-- Quiz Content Layout -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutQuizContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <LinearLayout
            android:id="@+id/llQuizHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_timer"
                app:tint="@color/study_blue_primary" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="00:00"
                android:textColor="@color/study_blue_primary"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvProgressText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Question 1/10"
                android:textColor="@color/study_blue_dark"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/quizProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            android:progressDrawable="@drawable/custom_progress_bar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llQuizHeader" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintBottom_toTopOf="@id/btnNext"
            app:layout_constraintTop_toBottomOf="@id/quizProgressBar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">

                    <TextView
                        android:id="@+id/tvQuestion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="24dp"
                        android:text="Loading question..."
                        android:textColor="@color/study_blue_dark"
                        android:textSize="18sp"
                        android:lineSpacingExtra="4dp" />
                </com.google.android.material.card.MaterialCardView>

                <RadioGroup
                    android:id="@+id/rgOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbOption1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/selector_option_bg"
                        android:button="@null"
                        android:padding="16dp"
                        android:text="Option 1"
                        android:textColor="@color/study_blue_dark" />

                    <RadioButton
                        android:id="@+id/rbOption2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/selector_option_bg"
                        android:button="@null"
                        android:padding="16dp"
                        android:text="Option 2"
                        android:textColor="@color/study_blue_dark" />

                    <RadioButton
                        android:id="@+id/rbOption3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/selector_option_bg"
                        android:button="@null"
                        android:padding="16dp"
                        android:text="Option 3"
                        android:textColor="@color/study_blue_dark" />

                    <RadioButton
                        android:id="@+id/rbOption4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/selector_option_bg"
                        android:button="@null"
                        android:padding="16dp"
                        android:text="Option 4"
                        android:textColor="@color/study_blue_dark" />
                </RadioGroup>
            </LinearLayout>
        </ScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_margin="24dp"
            android:text="@string/btn_next"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:backgroundTint="@color/study_blue_dark"
            app:cornerRadius="16dp"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Quiz Result Layout -->
    <LinearLayout
        android:id="@+id/layoutQuizResult"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:src="@drawable/ic_trophy" />

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_bulb"
                android:layout_gravity="top|end"
                android:layout_marginTop="-10dp"
                android:layout_marginEnd="-20dp"
                android:rotation="20" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_congratulations"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/study_blue_dark"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvScoreDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You scored 8 out of 10"
            android:textSize="18sp"
            android:textColor="@color/gray_text"
            android:layout_marginBottom="48dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackToHome"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/btn_back_to_home"
            android:backgroundTint="@color/study_blue_dark"
            app:cornerRadius="16dp"
            style="@style/Widget.MaterialComponents.Button" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
